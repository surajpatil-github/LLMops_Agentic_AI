FROM jenkins/jenkins:lts

USER root

# OS packages: Python, Docker CLI, curl, git
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    python3-venv \
    git \
    curl \
    ca-certificates \
    lsb-release \
    gnupg \
    docker.io \
    && rm -rf /var/lib/apt/lists/*

# python → python3 symlink
RUN ln -sf /usr/bin/python3 /usr/bin/python

# Allow Jenkins to use the host Docker socket
RUN usermod -aG docker jenkins

# Trust all directories (fixes "dubious ownership" git errors inside Jenkins)
RUN git config --system --add safe.directory '*'

# Pre-install plugins from file (one plugin per line — avoids multiline quoting issues)
COPY plugins.txt /usr/share/jenkins/ref/plugins.txt
RUN jenkins-plugin-cli --plugin-file /usr/share/jenkins/ref/plugins.txt

USER jenkins
